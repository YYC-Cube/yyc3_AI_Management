# YYC3 AI Management - Production Environment Variables
# 部署目标: api.yyc3.top
# 复制此文件为 .env.production 并填写实际值

# ==================== 应用配置 ====================
NODE_ENV=production
NEXT_PUBLIC_ENV=production
NEXT_PUBLIC_API_BASE_URL=https://api.yyc3.top

# 端口配置
PORT=3000
HOSTNAME=0.0.0.0

# ==================== 数据库配置 (PostgreSQL) ====================
DATABASE_URL="postgresql://yyc3_admin:Management@localhost:5432/yyc3_management"
DB_HOST=localhost
DB_PORT=5432
DB_NAME=yyc3_management
DB_USER=yyc3_admin
DB_PASSWORD=Management

# ==================== Redis 配置 ====================
REDIS_URL="redis://localhost:6379"
REDIS_HOST=localhost
REDIS_PORT=6379

# ==================== 认证配置 ====================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# ==================== 第三方服务 (可选) ====================
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ==================== 监控与日志 ====================
SENTRY_DSN=
LOG_LEVEL=info

# ==================== CI/CD Secrets (GitHub Actions) ====================
# 以下变量需要在 GitHub Repository Settings → Secrets 中配置:
#
# PRODUCTION_SSH_KEY: 生产服务器 SSH 私钥
# PRODUCTION_USER: SSH 用户名
# PRODUCTION_HOST: 生产服务器 IP/域名
# STAGING_DATABASE_URL: Staging 数据库连接串
# STAGING_REDIS_URL: Staging Redis 连接串
# STAGING_JWT_SECRET: Staging JWT 密钥
# VERCEL_TOKEN: Vercel API Token
# VERCEL_ORG_ID: Vercel 组织 ID
# VERCEL_PROJECT_ID: Vercel 项目 ID
# VERCEL_SCOPE: Vercel 范围
# SLACK_WEBHOOK_STAGING: Staging Slack Webhook
# SLACK_WEBHOOK_PRODUCTION: Production Slack Webhook
# CODECOV_TOKEN: Codecov 上传令牌
